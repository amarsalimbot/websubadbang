# ==========================================================================
# BOT KEUANGAN WA — Konfigurasi Environment
# Salin file ini menjadi .env lalu isi sesuai kebutuhan.
# Tidak ada kredensial yang boleh ditulis langsung di kode.
# ==========================================================================

# --- Wajib --------------------------------------------------------------
SPREADSHEET_ID=
WHATSAPP_PHONE_NUMBER=628xxxxxxxxxx

# Salah satu dari tiga opsi kredensial Google Service Account berikut:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- AI (opsional — bot tetap jalan dengan parser lokal tanpa ini) -------
OPENAI_API_KEY=
CHATGPT_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODELS=gpt-4o-mini,gpt-4o

GEMINI_API_KEY=
GEMINI_MODELS=gemini-1.5-flash,gemini-1.5-pro

AI_QUOTA_COOLDOWN_MINUTES=360
AI_RATE_LIMIT_COOLDOWN_MINUTES=2

# --- Dashboard web --------------------------------------------------------
DASHBOARD_SECRET=ganti-dengan-secret-acak-panjang
DASHBOARD_BASE_URL=
RAILWAY_PUBLIC_DOMAIN=
PUBLIC_BASE_URL=
APP_URL=
DASHBOARD_LINK_DAYS=30
SUPER_ADMIN_NUMBERS=
PORT=7860

# --- Binance (opsional, khusus satu nomor) --------------------------------
BINANCE_BALANCE_NUMBER=33827179200526
BINANCE_API_KEY_33827179200526=
BINANCE_API_SECRET_33827179200526=
