# ===== WhatsApp =====
WHATSAPP_PHONE_NUMBER=6281234567890
# WHATSAPP_AUTH_DIR=./session
ALLOW_SELF_CHAT=true
WA_MESSAGE_DEBUG=false
WA_LOG_LEVEL=silent

# ===== Umum =====
APP_TIMEZONE=Asia/Makassar
PORT=7860
DEFAULT_MODE=trader
DEFAULT_RISK_PERCENT=2

# ===== Watchlist =====
# Daftar kode aset (pisahkan koma), pilih dari katalog di src/config.js
WATCHLIST_SYMBOLS=BTC,ETH,BNB,SOL,XRP,PAXG,XAUT

# ===== Market data (Binance -> Bybit -> CoinGecko) =====
MARKET_DATA_PROVIDER=auto
BINANCE_API_KEY=
BINANCE_API_BASES=https://api.binance.com,https://data-api.binance.vision
BYBIT_API_BASE=https://api.bybit.com
COINGECKO_API_KEY=
COINGECKO_API_TYPE=demo
TICKER_CACHE_SECONDS=20
CANDLE_CACHE_MINUTES=2
FORCE_REFRESH_ON_REQUEST=true

# ===== Monitor & alert =====
MONITOR_INTERVAL_SECONDS=60
SIGNAL_COOLDOWN_MINUTES=45
POSITION_ALERT_COOLDOWN_MINUTES=15
POSITION_TRAILING_PERCENT=1.5

# ===== Auto report =====
AUTO_REPORT_ENABLED=true
AUTO_REPORT_MODE=candle
AUTO_REPORT_INTERVAL_MINUTES=60
AUTO_REPORT_START_DELAY_SECONDS=90
TRADER_CANDLE_MINUTES=15
INVESTOR_CANDLE_MINUTES=60
CANDLE_REPORT_DELAY_SECONDS=20

# ===== Backtest =====
BACKTEST_DEFAULT_DAYS=30
BACKTEST_MAX_CANDLES=1000

# ===== Paper trading (saldo virtual) =====
PAPER_STARTING_BALANCE=1000
PAPER_FEE_PERCENT=0.1

# ===== AI =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_WHISPER_MODEL=whisper-1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER_ORDER=openai,gemini
AI_AUTO_CHAT=true
AI_TIMEOUT_SECONDS=30
AI_PROVIDER_COOLDOWN_MINUTES=5
AI_HISTORY_TURNS=4
AI_HISTORY_TTL_MINUTES=60
AI_MAX_OUTPUT_TOKENS=1200
AI_MAX_OUTPUT_CHARS=3500
AI_VOICE_NOTES_ENABLED=true
AI_CHART_IMAGES_ENABLED=true

# ===== Web dashboard =====
WEB_DASHBOARD_ENABLED=true
# Isi untuk mewajibkan ?token=... pada /api/* dan dashboard
DASHBOARD_TOKEN=
